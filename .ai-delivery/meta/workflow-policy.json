{
  "version": 2,
  "truth_policy": {
    "functional_source": "Requirement",
    "visual_source": "Figma",
    "conflict_behavior": "block"
  },
  "workflow_gates": [
    "requirement_breakdown",
    "ui_truth_mapping",
    "spec_kit_pipeline",
    "implementation"
  ],
  "status_sequence": [
    "draft",
    "split_ready",
    "acceptance_frozen",
    "spec_ready",
    "plan_ready",
    "tasks_ready",
    "in_dev",
    "visual_acceptance_passed",
    "merged"
  ],
  "governance_events": [
    "screen_contract_frozen",
    "visual_acceptance_started",
    "visual_acceptance_passed",
    "visual_acceptance_failed"
  ],
  "source_index_policy": {
    "required_traceability_keys": [
      "requirement",
      "figma",
      "api",
      "spec_kit",
      "pr",
      "ci",
      "visual",
      "deploy",
      "monitoring"
    ]
  },
  "gate_requirements": {
    "ui_bearing_before_spec": ["acceptance_frozen"],
    "ui_bearing_before_plan": ["acceptance_frozen"],
    "ui_bearing_before_tasks": ["acceptance_frozen"],
    "ui_bearing_before_merge": ["visual_acceptance_passed"]
  },
  "worktree_policy": {
    "require_isolated_worktree": true,
    "allow_precreate_before_dependencies": false
  },
  "logging_policy": {
    "require_logs_for_main_session": true,
    "require_logs_for_subagent": true,
    "require_logs_for_state_change": true
  },
  "updated_at": "2026-05-06T00:00:00Z",
