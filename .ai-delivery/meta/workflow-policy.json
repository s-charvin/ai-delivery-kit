{
  "version": 2,
  "truth_policy": {
    "functional_source": "Requirement",
    "visual_source": "Figma",
    "acceptance_source": "UIAcceptanceContract",
    "interaction_source": "InteractionDesign",
    "conflict_behavior": "block"
  },
  "workflow_gates": [
    "requirement",
    "api_contract",
    "ui_evidence",
    "ui_acceptance_freeze",
    "interaction",
    "execution_prep",
    "development_review",
    "visual_acceptance_final_verification"
  ],
  "status_sequence": [
    "draft",
    "split_ready",
    "api_mapped",
    "figma_mapped",
    "acceptance_frozen",
    "interaction_ready",
    "slices_ready",
    "spec_ready",
    "plan_ready",
    "tasks_ready",
    "in_dev",
    "code_review_passed",
    "visual_acceptance_passed",
    "verified",
    "merged"
  ],
  "governance_events": [
    "screen_contract_started",
    "screen_contract_blocked",
    "screen_contract_frozen",
    "slice_synthesized",
    "visual_acceptance_started",
    "visual_acceptance_passed",
    "visual_acceptance_failed"
  ],
  "api_contract_policy": {
    "missing_default": "missing_nonblocking",
    "hard_block_statuses": [
      "blocked_api_contract_conflict",
      "blocked_requirement_api_conflict",
      "blocked_security_or_data_risk",
      "blocked_verification_failure"
    ]
  },
  "source_index_policy": {
    "required_traceability_keys": [
      "requirement",
      "figma",
      "api",
      "spec_kit",
      "pr",
      "ci",
      "visual",
      "deploy",
      "monitoring"
    ]
  },
  "gate_requirements": {
    "ui_bearing_before_spec": [
      "acceptance_frozen"
    ],
    "ui_bearing_before_plan": [
      "acceptance_frozen"
    ],
    "ui_bearing_before_tasks": [
      "acceptance_frozen"
    ],
    "ui_bearing_before_verified_or_merge": [
      "visual_acceptance_passed"
    ]
  },
  "spec_kit_bridge_policy": {
    "prepare_context_artifact": "spec-kit-input.md",
    "binding_artifact": "spec-kit-binding.json",
    "official_skills_are_upstream": true,
    "allow_repo_local_spec_kit_overrides": false,
    "bind_status_targets": [
      "spec_ready",
      "plan_ready",
      "tasks_ready"
    ]
  },
  "worktree_policy": {
    "require_isolated_worktree": true,
    "allow_precreate_before_dependencies": false
  },
  "logging_policy": {
    "require_logs_for_main_session": true,
    "require_logs_for_subagent": true,
    "require_logs_for_state_change": true
  },
  "updated_at": "2026-04-21T09:30:00Z",
  "updated_by": "codex-spec-kit-bridge-redesign"
}
