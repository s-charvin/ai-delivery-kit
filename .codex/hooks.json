{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/validate-ui-contract.sh\"",
            "timeout": 60,
            "statusMessage": "Validating UI acceptance contract"
          }
        ]
      }
    ]
  }
}
